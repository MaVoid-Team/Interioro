# Copy this file to .env on the VPS and replace every placeholder.
# Never commit the real .env file.

# Compose project and host bindings
COMPOSE_PROJECT_NAME=interioro
FRONTEND_PORT=9721
BACKEND_PORT=3409

# Public URLs used by redirects and payment callbacks
FRONTEND_URL=https://interioro.mavoid.com
BACKEND_URL=https://interioro.mavoid.com/api/v1

# Internal URL used by the Next.js server to call the backend container.
# Do not include /api/v1 here because the route handlers append it.
NEXT_PUBLIC_API_URL=http://backend:3000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=interioro
DB_PASS=replace-with-a-long-random-password
DB_NAME=interioro_db

# Backend auth
JWT_SECRET=replace-with-at-least-32-random-characters

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# Paymob
PAYMOB_SECRET_KEY=replace-me
PAYMOB_PUBLIC_KEY=replace-me
PAYMOB_INTEGRATION_ID=replace-me
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=replace-me
